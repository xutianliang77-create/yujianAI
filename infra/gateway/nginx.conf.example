limit_req_zone $binary_remote_addr zone=yujian_api:10m rate=20r/s;
limit_conn_zone $binary_remote_addr zone=yujian_conn:10m;

server {
  listen 443 ssl http2;
  server_name platform.example.invalid;
  ssl_protocols TLSv1.2 TLSv1.3;
  add_header Strict-Transport-Security "max-age=31536000" always;
  client_max_body_size 16k;
  location / {
    limit_req zone=yujian_api burst=40 nodelay;
    limit_conn yujian_conn 100;
    proxy_set_header X-Request-ID $request_id;
    proxy_set_header X-Forwarded-Proto https;
    proxy_pass http://yujian-platform-api:8090;
  }
}
