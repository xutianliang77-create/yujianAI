limit_req_zone $binary_remote_addr zone=yujian_api:10m rate=20r/s;
limit_conn_zone $binary_remote_addr zone=yujian_conn:10m;

log_format yujian_edge '$remote_addr $request_id $request_method $uri $status $body_bytes_sent $request_time';

server {
  listen 443 ssl http2;
  server_name platform.example.invalid;
  ssl_protocols TLSv1.2 TLSv1.3;
  server_tokens off;
  add_header Strict-Transport-Security "max-age=31536000" always;
  add_header X-Content-Type-Options nosniff always;
  client_max_body_size 16k;
  access_log /var/log/nginx/yujian-edge-access.log yujian_edge;
  location /platform/ {
    limit_req zone=yujian_api burst=40 nodelay;
    limit_conn yujian_conn 100;
    proxy_set_header X-Request-ID $request_id;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header Host $host;
    proxy_pass http://yujian-platform-api:8090;
  }
  location = /healthz { proxy_pass http://yujian-platform-api:8090; }
  location / { return 404; }
}
