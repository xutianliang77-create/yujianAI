{
  "title": "Yujian SIP and Media Quality",
  "uid": "yujian-media-quality",
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "SIP answer rate",
      "targets": [{ "expr": "sum(rate(yujian_sip_calls_total{answered=\"true\"}[15m])) / clamp_min(sum(rate(yujian_sip_calls_total[15m])), 0.001)" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 post dial delay ms",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(yujian_sip_post_dial_delay_ms_bucket[15m])))" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Terminal reasons",
      "targets": [{ "expr": "sum by (provider, terminal_reason) (rate(yujian_sip_calls_total[15m]))" }]
    }
  ]
}
