{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "required": ["image", "replicaCount", "service", "secrets", "features", "rtc", "turn", "dataServices", "gateway", "observability"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["platformApi", "rtc", "postgres", "redis", "pullPolicy"],
      "properties": {
        "platformApi": { "type": "string", "minLength": 1 },
        "rtc": { "type": "string", "minLength": 1 },
        "rtcCapacityExporter": { "type": "string" },
        "mediaOps": { "type": "string", "minLength": 1 },
        "agentControl": { "type": "string", "minLength": 1 },
        "agentWorker": { "type": "string", "minLength": 1 },
        "postgres": { "type": "string", "minLength": 1 },
        "redis": { "type": "string", "minLength": 1 },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": { "type": "array", "items": { "type": "object" } }
      }
    },
    "replicaCount": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 1 } },
    "service": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 1, "maximum": 65535 } },
    "features": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "secrets": {
      "type": "object",
      "required": ["existingSecret", "platformCredentials", "rtcApiKey", "rtcApiSecret", "rtcConfig"],
      "properties": {
        "existingSecret": { "type": "string", "minLength": 1 },
        "platformCredentials": { "type": "string", "minLength": 1 },
        "rtcApiKey": { "type": "string", "minLength": 1 },
        "rtcApiSecret": { "type": "string", "minLength": 1 },
        "rtcConfig": { "type": "string", "minLength": 1 },
        "rtcCapacityCredential": { "type": "string", "minLength": 1 },
        "agentControlCredential": { "type": "string", "minLength": 1 },
        "agentControlAdminCredential": { "type": "string", "minLength": 1 },
        "mediaOpsCredential": { "type": "string", "minLength": 1 },
        "mediaOpsProviderCallbackCredential": { "type": "string", "minLength": 1 }
      }
    },
    "rtc": {
      "type": "object",
      "required": ["primaryWsUrl", "configSecretKey", "capacity"],
      "properties": {
        "primaryWsUrl": { "type": "string" },
        "secondaryWsUrl": { "type": "string" },
        "configSecretKey": { "type": "string", "minLength": 1 },
        "capacity": {
          "type": "object",
          "required": ["intervalMs", "ttlMs", "maxRooms", "maxParticipants", "maxPublishers", "maxSubscriptions", "maxTracks"],
          "additionalProperties": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "turn": {
      "type": "object",
      "required": ["replicas", "configSecret", "configKey", "tlsSecret", "serviceType", "externalTrafficPolicy", "relayPortMin", "relayPortMax", "publicUrls", "secretRef"],
      "properties": {
        "replicas": { "type": "integer", "minimum": 2, "maximum": 20 },
        "configSecret": { "type": "string", "minLength": 1 },
        "configKey": { "type": "string", "minLength": 1 },
        "tlsSecret": { "type": "string", "minLength": 1 },
        "serviceType": { "enum": ["LoadBalancer", "NodePort"] },
        "externalTrafficPolicy": { "enum": ["Local", "Cluster"] },
        "relayPortMin": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "relayPortMax": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "annotations": { "type": "object" },
        "publicUrls": { "type": "array", "minItems": 0, "maxItems": 16, "items": { "type": "string", "pattern": "^turns?:" } },
        "secretRef": { "type": "string", "maxLength": 512 }
      }
    },
    "dataServices": {
      "type": "object",
      "required": ["mode", "externalEgressCidrs", "postgresPort", "redisPort", "enforceProductionTopology", "postgresTls", "redisTls", "postgresZones", "redisZones", "topologyEvidenceRef"],
      "allOf": [{
        "if": { "properties": { "enforceProductionTopology": { "const": true } } },
        "then": {
          "properties": {
            "mode": { "const": "external-ha" },
            "postgresTls": { "const": true },
            "redisTls": { "const": true },
            "postgresZones": { "minimum": 3 },
            "redisZones": { "minimum": 3 },
            "topologyEvidenceRef": { "minLength": 1 }
          }
        }
      }],
      "properties": {
        "mode": { "enum": ["external-ha", "embedded-single"] },
        "externalEgressCidrs": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$" } },
        "postgresPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "redisPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "enforceProductionTopology": { "type": "boolean" },
        "postgresTls": { "type": "boolean" },
        "redisTls": { "type": "boolean" },
        "postgresZones": { "type": "integer", "minimum": 1, "maximum": 32 },
        "redisZones": { "type": "integer", "minimum": 1, "maximum": 32 },
        "topologyEvidenceRef": { "type": "string", "maxLength": 512, "pattern": "^(?:$|(evidence|https|s3|gs|oss)://[^?#]+)$" }
      }
    },
    "gateway": {
      "type": "object",
      "required": ["enabled", "ingressClassName", "host", "tlsSecret", "annotations", "controllerNamespaceSelector", "controllerPodSelector", "wafPolicyRef", "ddosPolicyRef", "certificateRolloverPlanRef"],
      "allOf": [{
        "if": { "properties": { "enabled": { "const": true } } },
        "then": { "properties": {
          "ingressClassName": { "minLength": 1 },
          "host": { "minLength": 1 },
          "tlsSecret": { "minLength": 1 },
          "controllerNamespaceSelector": { "minProperties": 1 },
          "controllerPodSelector": { "minProperties": 1 },
          "wafPolicyRef": { "minLength": 1 },
          "ddosPolicyRef": { "minLength": 1 },
          "certificateRolloverPlanRef": { "minLength": 1 }
        } }
      }],
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressClassName": { "type": "string", "maxLength": 128, "pattern": "^(?:|[a-z0-9](?:[-a-z0-9.]*[a-z0-9])?)$" },
        "host": { "type": "string", "maxLength": 253, "pattern": "^(?:|(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z]{2,63})$" },
        "tlsSecret": { "type": "string", "maxLength": 253, "pattern": "^(?:|[a-z0-9](?:[-a-z0-9.]*[a-z0-9])?)$" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string", "maxLength": 2048 } },
        "controllerNamespaceSelector": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 128 } },
        "controllerPodSelector": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 128 } },
        "wafPolicyRef": { "type": "string", "maxLength": 512, "pattern": "^(?:$|(evidence|https|s3|gs|oss)://)" },
        "ddosPolicyRef": { "type": "string", "maxLength": 512, "pattern": "^(?:$|(evidence|https|s3|gs|oss)://)" },
        "certificateRolloverPlanRef": { "type": "string", "maxLength": 512, "pattern": "^(?:$|(evidence|https|s3|gs|oss)://)" }
      }
    },
    "observability": {
      "type": "object",
      "required": ["rtcTelemetryRetentionDays"],
      "properties": {
        "rtcTelemetryRetentionDays": { "type": "integer", "minimum": 1, "maximum": 90 }
      }
    },
    "platformRuntime": {
      "type": "object",
      "properties": {
        "modulePath": { "type": "string", "maxLength": 512 },
        "postgresUrlSecretKey": { "type": "string", "maxLength": 128 },
        "redisUrlSecretKey": { "type": "string", "maxLength": 128 },
        "kmsEgressCidrs": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$" } },
        "kmsPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "externalHttpsEgressCidrs": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$" } }
      }
    },
    "mediaOps": {
      "type": "object",
      "properties": {
        "providerEnabled": { "type": "boolean" },
        "persistenceModulePath": { "type": "string", "maxLength": 512, "description": "Deployment ESM module exporting persistence, provider, admission, retention and reconciliation factories required by enabled media features." },
        "rtcPrimaryUrl": { "type": "string" },
        "rtcSecondaryUrl": { "type": "string" },
        "defaultSipTrunkId": { "type": "string", "maxLength": 128 },
        "externalHttpsEgressCidrs": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$" } },
        "workloadIdentity": {
          "type": "object",
          "required": ["enabled", "serviceAccountName", "audience", "expirationSeconds"],
          "properties": {
            "enabled": { "type": "boolean" },
            "serviceAccountName": { "type": "string", "maxLength": 253 },
            "audience": { "type": "string", "minLength": 1, "maxLength": 253 },
            "expirationSeconds": { "type": "integer", "minimum": 600, "maximum": 3600 }
          }
        },
        "baseUrl": { "type": "string" },
        "tls": { "type": "object" }
      }
    },
    "agent": {
      "type": "object",
      "properties": {
        "environmentId": { "type": "string", "maxLength": 128 },
        "handlerModulePath": { "type": "string", "maxLength": 512 },
        "nodeSelector": { "type": "object" },
        "gpuResource": { "type": "string", "maxLength": 128 },
        "gpuCount": { "type": "integer", "minimum": 1, "maximum": 1 },
        "providerEgressCidrs": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$" } },
        "workloadIdentity": {
          "type": "object",
          "required": ["enabled", "serviceAccountName", "audience", "expirationSeconds"],
          "properties": {
            "enabled": { "type": "boolean" },
            "serviceAccountName": { "type": "string", "maxLength": 253 },
            "audience": { "type": "string", "minLength": 1, "maxLength": 253 },
            "expirationSeconds": { "type": "integer", "minimum": 600, "maximum": 3600 }
          }
        }
      }
    },
    "agentControl": {
      "type": "object",
      "properties": {
        "persistenceModulePath": { "type": "string", "maxLength": 512 },
        "dispatchQuotaModulePath": { "type": "string", "maxLength": 512 },
        "artifactVerifierModulePath": { "type": "string", "maxLength": 512 },
        "externalHttpsEgressCidrs": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$" } },
        "baseUrl": { "type": "string" },
        "tls": { "type": "object" }
      }
    },
    "security": { "type": "object", "required": ["runAsUser", "runAsGroup", "fsGroup", "readOnlyRootFilesystem"] }
  }
}
