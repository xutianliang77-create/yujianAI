# Build context: repository root. This image is an optional Python Agent
# runtime for the single Beelink RTX 5090 worker; it does not contain secrets.
FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1

COPY services/agent-worker-python/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir --disable-pip-version-check -r requirements.txt
COPY services/agent-worker-python/worker.py ./worker.py
COPY services/agent-worker-python/livekit_room.py ./livekit_room.py

USER 10001:10001
ENTRYPOINT ["python", "worker.py"]
