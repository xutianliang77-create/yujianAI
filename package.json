{
  "name": "yujian-ai",
  "version": "0.1.0",
  "private": true,
  "description": "语见AI - 中国本土化、LiveKit 兼容的实时音视频与 AI Agent 平台",
  "workspaces": [
    "services/*",
    "packages/livekit-compat",
    "packages/platform-contracts",
    "packages/restricted-client-adapter"
  ],
  "scripts": {
    "check": "npm run verify:upstream && npm run lint --if-present --workspaces && npm run test --if-present --workspaces",
    "build": "npm run build --if-present --workspaces",
    "lint": "npm run lint --if-present --workspaces",
    "test": "npm run test --if-present --workspaces",
    "verify:upstream": "node tools/upstream/verify-livekit-manifest.mjs && npm run test:upstream:replay",
    "verify:upstream:network": "node tools/upstream/verify-livekit-manifest.mjs --network",
    "test:upstream:replay": "node --test tools/upstream/replay-patch-queue.test.mjs",
    "upstream:mirror:sync": "node tools/upstream/sync-clean-mirrors.mjs",
    "upstream:patch:replay": "node tools/upstream/replay-patch-queue.mjs",
    "rtc:up": "docker compose -f infra/livekit/local/compose.yaml up -d",
    "rtc:down": "docker compose -f infra/livekit/local/compose.yaml down",
    "rtc:logs": "docker compose -f infra/livekit/local/compose.yaml logs -f yujian-rtc-a yujian-rtc-b",
    "test:integration:rtc": "npm run build && node --test tests/integration/platform-rtc-smoke.test.mjs",
    "build:compat:web": "esbuild tests/compatibility/web/src/main.js --bundle --format=esm --platform=browser --target=chrome120 --outfile=tests/compatibility/web/dist/main.js",
    "build:compat:flutter": "node tools/compatibility/build-flutter-harness.mjs",
    "compat:web:serve": "npm run build:compat:web && node tools/compatibility/serve-web-harness.mjs",
    "beelink:preflight": "bash tools/beelink/preflight.sh",
    "beelink:acceptance": "bash tools/beelink/run-acceptance.sh",
    "client:preflight": "bash tools/client/preflight.sh",
    "client:acceptance": "bash tools/client/run-acceptance.sh",
    "ops:probe": "node tools/ops/synthetic-probe.mjs",
    "ops:stability": "node tools/ops/run-stability-probe.mjs",
    "ops:support-bundle": "node tools/ops/create-support-bundle.mjs",
    "ops:control-plane-backup": "node tools/ops/run-control-plane-backup.mjs",
    "ops:create-status-event": "node tools/ops/create-status-event.mjs",
    "release:preflight": "node tools/release/preflight.mjs",
    "release:create-security-audit": "node tools/security/create-audit-manifest.mjs",
    "release:create-rc-freeze": "node tools/release/create-rc-freeze.mjs",
    "release:create-ga-decision": "node tools/release/create-ga-decision.mjs",
    "private:upgrade-preflight": "node tools/private-deployment/upgrade-preflight.mjs",
    "private:create-offline-bundle": "node tools/private-deployment/create-offline-bundle.mjs",
    "private:create-acceptance-report": "node tools/private-deployment/create-acceptance-report.mjs",
    "private:capacity-plan": "node tools/capacity/calculate-private-deployment.mjs",
    "private:issue-license": "node tools/private-deployment/issue-license.mjs",
    "gateway:verify-certificate-rollover": "node tools/gateway/verify-certificate-rollover.mjs",
    "p1:evidence:verify": "node tools/acceptance/verify-p1-evidence.mjs",
    "m3:execution-plan": "node tools/acceptance/create-m3-preview-execution-plan.mjs",
    "m3:evidence:verify": "node tools/acceptance/verify-m3-preview-evidence.mjs",
    "m7:evidence:verify": "node tools/acceptance/verify-m7-evidence.mjs",
    "db:migrate": "node tools/database/migrate.mjs",
    "openapi:verify": "ruby tools/api/verify-openapi.rb docs/api/openapi.yaml",
    "supply-chain:sbom": "node tools/supply-chain/generate-sbom.mjs",
    "supply-chain:verify": "npm run supply-chain:sbom && node tools/supply-chain/verify-sbom.mjs",
    "supply-chain:verify-signature": "node tools/supply-chain/verify-signature.mjs",
    "supply-chain:verify-image-evidence": "node tools/supply-chain/verify-image-evidence.mjs",
    "supply-chain:verify-candidate-evidence": "node tools/supply-chain/verify-image-candidate-evidence.mjs",
    "supply-chain:verify-remediated-evidence": "node tools/supply-chain/verify-remediated-candidate-evidence.mjs",
    "supply-chain:verify-license-remediation": "node tools/supply-chain/verify-license-remediation-evidence.mjs",
    "supply-chain:verify-redis-decision": "node tools/supply-chain/verify-redis-release-decision.mjs",
    "supply-chain:verify-owner-signoffs": "node tools/supply-chain/verify-owner-signoffs.mjs",
    "supply-chain:verify-owner-templates": "for file in docs/governance/owner-decisions/*-decision.json; do node tools/supply-chain/verify-owner-decision.mjs \"$file\"; done",
    "supply-chain:verify-owner-keys": "node tools/supply-chain/verify-owner-key-registry.mjs",
    "supply-chain:verify-production-oci": "node tools/supply-chain/verify-production-oci-evidence.mjs",
    "supply-chain:verify-registry-kms-freeze": "P1_M0_04_REGISTRY_KMS_IMPLEMENTATION=docs/acceptance/p1-registry-kms-freeze-implementation.json node tools/supply-chain/verify-registry-kms-freeze.mjs",
    "supply-chain:prepare-registry-kms-freeze": "node tools/supply-chain/prepare-registry-kms-freeze.mjs",
    "test:supply-chain": "node --test tools/supply-chain/*.test.mjs",
    "owner-approval:start": "npm start -w @yujian/owner-approval",
    "owner-approval:test": "npm test -w @yujian/owner-approval",
    "owner-approval:bypass-clash": "node tools/owner-approval/bypass-clash-proxy.mjs",
    "yujian:cli": "node tools/cli/yujian.mjs"
  },
  "devDependencies": {
    "@livekit/rtc-node": "0.13.31",
    "esbuild": "0.28.1",
    "livekit-client": "2.20.1"
  },
  "engines": {
    "node": ">=22 <25"
  }
}
