MEDIA_OPS_HOST=127.0.0.1
MEDIA_OPS_PORT=8095
YUJIAN_MEDIA_INTERNAL_CREDENTIAL=<set-a-random-32-character-or-longer-internal-credential>
YUJIAN_SIP_ENABLED=false
YUJIAN_SIP_DEFAULT_TRUNK_ID=<optional-default-trunk-id>
YUJIAN_INGRESS_ENABLED=true
YUJIAN_EGRESS_ENABLED=false
YUJIAN_MEDIA_PROVIDER_ENABLED=false
# Required only when provider is enabled; use HTTPS/WSS outside loopback.
YUJIAN_RTC_PRIMARY_URL=ws://127.0.0.1:7880
YUJIAN_RTC_SECONDARY_URL=ws://127.0.0.1:7980
YUJIAN_RTC_API_KEY=<set-a-livekit-api-key>
YUJIAN_RTC_API_SECRET=<set-a-livekit-api-secret>
# Optional internal TLS files for non-loopback deployment.
# MEDIA_OPS_TLS_CERT_FILE=/var/run/yujian-tls/tls.crt
# MEDIA_OPS_TLS_KEY_FILE=/var/run/yujian-tls/tls.key
