PLATFORM_API_HOST=127.0.0.1
PLATFORM_API_PORT=8090
YUJIAN_PLATFORM_CREDENTIALS_JSON=[{"tenantId":"tenant-preview","projectId":"project-demo","environmentId":"environment-local","credential":"<set-a-random-32-character-or-longer-credential>","roles":["developer"]}]
YUJIAN_PLATFORM_ADMIN_CREDENTIAL=<set-a-random-32-character-or-longer-admin-credential>
YUJIAN_API_KEY_GRACE_MS=300000
# Optional exact origin for the static console; leave unset for server-only/same-origin use.
# YUJIAN_PLATFORM_CORS_ORIGIN=https://console.example.cn
# Optional deployment-owned module exporting createPlatformRuntime({ config }) for PG/Redis/KMS,
# storePersistence, billing, data-rights, resourceUsage and tokenQuota adapters. Keep credentials
# out of this repository; production requires all durable/distributed adapters.
# YUJIAN_PLATFORM_RUNTIME_MODULE=/etc/yujian/platform-runtime.mjs
YUJIAN_RTC_PRIMARY_URL=ws://127.0.0.1:7880
YUJIAN_RTC_SECONDARY_URL=ws://127.0.0.1:7980
YUJIAN_RTC_API_KEY=<set-a-livekit-api-key>
YUJIAN_RTC_API_SECRET=<set-a-livekit-api-credential>
YUJIAN_MEDIA_OPS_URL=http://127.0.0.1:8095
YUJIAN_MEDIA_OPS_CREDENTIAL=<set-a-random-32-character-or-longer-internal-credential>
# LIVEKIT_URL/LIVEKIT_API_KEY/LIVEKIT_API_SECRET remain accepted as one-node compatibility fallbacks.
