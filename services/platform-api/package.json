{
  "name": "@yujian/platform-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "语见AI最小中国控制面 API",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "npm run build -w @yujian/platform-contracts && npm run build -w @yujian/livekit-compat",
    "build": "tsc -p tsconfig.json",
    "prelint": "npm run build -w @yujian/platform-contracts && npm run build -w @yujian/livekit-compat",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@yujian/livekit-compat": "0.1.0",
    "@yujian/platform-contracts": "0.1.0",
    "pg": "8.16.3",
    "redis": "4.7.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "livekit-server-sdk": "2.17.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22 <25"
  }
}
