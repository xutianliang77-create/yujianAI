AGENT_CONTROL_HOST=127.0.0.1
AGENT_CONTROL_PORT=8096
YUJIAN_AGENT_INTERNAL_CREDENTIAL=<set-a-random-32-character-or-longer-worker-credential>
YUJIAN_AGENT_ADMIN_CREDENTIAL=<set-a-separate-random-32-character-or-longer-admin-credential>
# Production module exporting createAgentControlPersistence() and using an external SQL pool.
# YUJIAN_AGENT_CONTROL_PERSISTENCE_MODULE=/etc/yujian/agent-control-runtime.mjs
# Production module exporting createAgentArtifactVerifier() for OCI signature/SBOM checks.
# YUJIAN_AGENT_ARTIFACT_VERIFIER_MODULE=/etc/yujian/agent-verifier-runtime.mjs
# AGENT_CONTROL_TLS_CERT_FILE=/var/run/yujian-tls/tls.crt
# AGENT_CONTROL_TLS_KEY_FILE=/var/run/yujian-tls/tls.key
