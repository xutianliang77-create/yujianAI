YUJIAN_OWNER_APPROVAL_HOST=127.0.0.1
YUJIAN_OWNER_APPROVAL_PORT=8093
YUJIAN_OWNER_APPROVAL_EVIDENCE_ROOT=/data/models/yujianAI/evidence/p1-m0-04/owner-approvals
YUJIAN_OWNER_OPENBAO_ADDRS=https://127.0.0.1:18200,https://127.0.0.1:18201,https://127.0.0.1:18202
NODE_EXTRA_CA_CERTS=/data/models/yujianAI/p2/openbao-tls/ca.crt

# Required when binding beyond loopback. Use a Tailscale/internal certificate, never plaintext HTTP.
# YUJIAN_OWNER_APPROVAL_HOST=100.110.127.117
# YUJIAN_OWNER_APPROVAL_TLS_CERT=/data/models/yujianAI/owner-approval/tls/server.crt
# YUJIAN_OWNER_APPROVAL_TLS_KEY=/data/models/yujianAI/owner-approval/tls/server.key

# Optional absolute overrides. Defaults point at this repository checkout.
# YUJIAN_OWNER_APPROVAL_ASSET_ROOT=/path/to/yujianAI/apps/owner-approval
# YUJIAN_OWNER_APPROVAL_TEMPLATE_ROOT=/path/to/yujianAI/docs/governance/owner-decisions
# YUJIAN_OWNER_KEY_REGISTRY=/path/to/yujianAI/docs/acceptance/p1-owner-key-registry.json
