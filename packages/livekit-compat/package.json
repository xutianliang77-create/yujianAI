{
  "name": "@yujian/livekit-compat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "语见AI对 LiveKit 官方 Server SDK 的最小兼容适配层",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "npm run build -w @yujian/platform-contracts",
    "build": "tsc -p tsconfig.json",
    "prelint": "npm run build -w @yujian/platform-contracts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@yujian/platform-contracts": "0.1.0",
    "livekit-server-sdk": "2.17.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22 <25"
  }
}
