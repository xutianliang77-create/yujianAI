{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yujian.ai/contracts/v1/common.schema.json",
  "title": "Yujian AI Common Contract Types v1",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "languageTag": {
      "type": "string",
      "minLength": 2,
      "maxLength": 35,
      "pattern": "^(und|[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*)$"
    },
    "communicationSessionId": {
      "$ref": "#/$defs/uuid"
    },
    "participantId": {
      "$ref": "#/$defs/uuid"
    },
    "legId": {
      "$ref": "#/$defs/uuid"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    }
  }
}
