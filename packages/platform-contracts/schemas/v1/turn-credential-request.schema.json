{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yujian.ai/platform/v1/turn-credential-request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["tenantId", "projectId", "environmentId", "participantIdentity"],
  "properties": {
    "tenantId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "projectId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "environmentId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "participantIdentity": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[^\\u0000-\\u001f\\u007f]+$" },
    "ttlSeconds": { "type": "integer", "minimum": 60, "maximum": 3600, "default": 600 }
  }
}
