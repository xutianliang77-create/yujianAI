{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yujian.ai/platform/v1/issue-room-token-request.schema.json",
  "title": "IssueRoomTokenRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenantId",
    "projectId",
    "environmentId",
    "roomName",
    "participantIdentity"
  ],
  "properties": {
    "tenantId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "environmentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "roomName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\u0000-\\u001f\\u007f]+$"
    },
    "participantIdentity": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\u0000-\\u001f\\u007f]+$"
    },
    "participantName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\u0000-\\u001f\\u007f]+$"
    },
    "metadata": {
      "type": "string",
      "maxLength": 4096
    },
    "attributes": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": {
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^(?!yujian\\.)[^\\u0000-\\u001f\\u007f]+$"
      },
      "additionalProperties": {
        "type": "string",
        "maxLength": 256,
        "pattern": "^[^\\u0000-\\u001f\\u007f]*$"
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canPublish": {
          "type": "boolean"
        },
        "canSubscribe": {
          "type": "boolean"
        },
        "canPublishData": {
          "type": "boolean"
        }
      }
    },
    "ttlSeconds": {
      "type": "integer",
      "minimum": 60,
      "maximum": 300
    }
  }
}
